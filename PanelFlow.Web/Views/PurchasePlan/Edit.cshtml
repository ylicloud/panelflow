@model PanelFlow.Web.Models.Purchase.PurchasePlanEditViewModel
@using PanelFlow.Core.Models
@{
    ViewData["Title"] = $"编辑采购计划 {Model.Plan.PlanNo}";
    var plan = Model.Plan;
}

<link rel="stylesheet" href="~/lib/handsontable/handsontable.full.min.css" />

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h5 class="fw-bold mb-0"><i class="bi bi-clipboard-data me-2"></i>采购计划 @plan.PlanNo</h5>
    <div class="d-flex flex-wrap gap-2">
        @if (Model.CanEdit)
        {
            <button type="button" id="btnSave" class="btn btn-sm btn-primary"><i class="bi bi-save me-1"></i>保存</button>
            <button type="button" id="btnAddRow" class="btn btn-sm btn-outline-success"><i class="bi bi-plus me-1"></i>新增行</button>
        }
        @if (Model.CanEdit && plan.Status == PurchasePlanStatus.Draft)
        {
            <form method="post" asp-action="Issue" asp-route-id="@plan.Id" class="d-inline"
                  onsubmit="return confirm('确认下达此采购计划？下达后采购人员可见。');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-warning"><i class="bi bi-send me-1"></i>下达</button>
            </form>
        }
        <div class="btn-group">
            <a href="@Url.Action("PrintReport1", new { id = plan.Id })" class="btn btn-sm btn-outline-secondary" target="_blank">计划表 PDF</a>
            <a href="@Url.Action("PrintReport1", new { id = plan.Id, showDeleted = true })" class="btn btn-sm btn-outline-secondary" target="_blank">含删除行</a>
        </div>
        <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">返回</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success py-2 small">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger py-2 small">@TempData["ErrorMessage"]</div>
}

<div class="oa-card mb-3">
    <div class="row g-2 small">
        <div class="col-md-3"><strong>方案编号：</strong>@plan.Fabh</div>
        <div class="col-md-3"><strong>合同编号：</strong>@(plan.ContractNo ?? "—")</div>
        <div class="col-md-3"><strong>合同名称：</strong>@(plan.ContractName ?? "—")</div>
        <div class="col-md-3"><strong>状态：</strong>@plan.StatusText</div>
    </div>
</div>

<div class="oa-card p-2">
    <div id="hotContainer"></div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/lib/handsontable/handsontable.full.min.js"></script>
    <script>
        window.purchasePlanEdit = {
            planId: @plan.Id,
            canEdit: @(Model.CanEdit ? "true" : "false"),
            saveUrl: '@Url.Action("SaveItems", new { id = plan.Id })',
            items: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(plan.Items, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))
        };
    </script>
    <script src="~/js/purchase-plan-edit.js" asp-append-version="true"></script>
}
