@model PanelFlow.Web.Models.Purchase.PurchasePlanCreateViewModel
@{
    ViewData["Title"] = "新建采购计划";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-plus-circle me-2"></i>新建采购计划</h5>
    <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">返回列表</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger py-2 small">@TempData["ErrorMessage"]</div>
}

<div class="oa-card" style="max-width: 560px;">
    <form method="post" asp-action="Create">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label">报价单方案编号（fabh）<span class="text-danger">*</span></label>
            <input asp-for="Fabh" class="form-control" placeholder="请输入方案编号" required />
            <div class="form-text">请先在报价单「汇总中心」执行汇总，生成 BJB_XMYJHZ 数据后再创建计划。</div>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">从汇总表导入并创建</button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">取消</a>
        </div>
    </form>
</div>
