@model PanelFlow.Web.Controllers.QuotationEditViewModel
@{
    ViewData["Title"] = "编辑报价单";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2"></i>编辑报价单</h5>
    <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>返回列表
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success py-2 small alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger py-2 small alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
    </div>
}

<div class="oa-card">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
        <input asp-for="QuotationNo" type="hidden" />

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">报价单编号</label>
                <input class="form-control form-control-sm" value="@Model.QuotationNo" readonly />
                @if (Model.CanRenameFabh)
                {
                    <div class="mt-1">
                        <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none"
                                data-bs-toggle="modal" data-bs-target="#renameFabhModal">
                            编号录入有误？申请修改
                        </button>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(Model.RenameFabhBlockedReason))
                {
                    <div class="small text-muted mt-1">@Model.RenameFabhBlockedReason</div>
                }
            </div>
            <div class="col-md-4">
                <label asp-for="QuotationName" class="form-label"></label>
                <input asp-for="QuotationName" class="form-control form-control-sm" />
                <span asp-validation-for="QuotationName" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label class="form-label">客户关键字搜索</label>
                <div class="input-group input-group-sm">
                    <input type="text" id="customerKeyword" class="form-control"
                           placeholder="输入公司名称或别名关键字（仅检索已填写别名的客户）" />
                    <button class="btn btn-outline-secondary" type="button" id="customerSearchBtn">搜索</button>
                </div>
                <div id="customerSearchHint" class="small text-muted mt-1">请输入关键字后选择客户</div>
                <div id="customerSearchResult" class="list-group mt-2 d-none"></div>
            </div>

            <div class="col-md-4">
                <label asp-for="CustomerNo" class="form-label"></label>
                <input asp-for="CustomerNo" class="form-control form-control-sm" readonly />
                <span asp-validation-for="CustomerNo" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="CustomerName" class="form-label"></label>
                <input asp-for="CustomerName" class="form-control form-control-sm" readonly />
                <span asp-validation-for="CustomerName" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="CustomerAlias" class="form-label"></label>
                <input asp-for="CustomerAlias" class="form-control form-control-sm" readonly />
                <span asp-validation-for="CustomerAlias" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Remark" class="form-label"></label>
                <input asp-for="Remark" class="form-control form-control-sm" />
                <span asp-validation-for="Remark" class="text-danger small"></span>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-primary">
                <i class="bi bi-check2 me-1"></i>保存修改
            </button>
            <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">取消</a>
        </div>
    </form>
</div>

@if (Model.CanRenameFabh)
{
    <div class="modal fade" id="renameFabhModal" tabindex="-1" aria-labelledby="renameFabhModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="RenameQuotationNo" method="post" id="renameFabhForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.QuotationNo" />
                    <div class="modal-header">
                        <h6 class="modal-title" id="renameFabhModalLabel">修改方案编号</h6>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="关闭"></button>
                    </div>
                    <div class="modal-body">
                        <p class="small text-muted mb-3">
                            仅用于创建时编号录错。改号后 BJB 等关联表将同步更新，且无法在本页撤销。
                        </p>
                        <div class="mb-3">
                            <label class="form-label">原方案编号</label>
                            <input class="form-control form-control-sm" value="@Model.QuotationNo" readonly />
                        </div>
                        <div class="mb-0">
                            <label class="form-label" for="newQuotationNo">新方案编号</label>
                            <input type="text" class="form-control form-control-sm" id="newQuotationNo"
                                   name="newQuotationNo" maxlength="20" required
                                   placeholder="请输入新的方案编号" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                        <button type="submit" class="btn btn-sm btn-warning" id="renameFabhSubmitBtn">确认修改编号</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/quotation-edit.js" asp-append-version="true"></script>
    <script>
        window.quotationEditConfig = {
            searchCustomersUrl: "@Url.Action("SearchCustomers", "Quotation")"
        };
    </script>
}
