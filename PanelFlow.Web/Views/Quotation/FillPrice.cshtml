@model PanelFlow.Web.Models.Quotation.QuotationPriceViewModel
@{
    ViewData["Title"] = "报价";
    var cabinetComponentsUrl = Url.Action("GetCabinetComponents", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var projectComponentSummaryUrl = Url.Action("GetProjectComponentSummary", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var saveProjectSummaryUrl = Url.Action("SaveProjectComponentSummary", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var cabinetRefBjUrl = Url.Action("GetCabinetReferenceBj", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var referencePriceUrl = Url.Action("GetReferencePrice", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var autoFillPriceUrl = Url.Action("AutoFillPriceFromHistory", "Quotation") ?? string.Empty;
    var fillProgressUrl = Url.Action("GetProjectFillProgress", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var wzdhSyncStatsUrl = Url.Action("GetComponentWzdhSyncStats", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var applyPriceByWzdhUrl = Url.Action("ApplyComponentPriceByWzdh", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var additionalItemsUrl = Url.Action("GetCabinetAdditionalItems", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var attributeItemsUrl = Url.Action("GetAttributeItems", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var saveLeafItemsUrl = Url.Action("SaveLeafItemFields", "Quotation") ?? string.Empty;
}
<link rel="stylesheet" href="~/lib/handsontable/handsontable.full.min.css" />
<style>
    /* 调整 ↓ 250px 这个数字可改变左右两栏高度：数字越大、两栏越矮（避免页面右侧出现垂直滚动条）。建议 250~320。 */
    .price-workspace { display: flex; gap: 0; height: calc(100vh - 250px); min-height: 360px; overflow: hidden; }
    .price-tree-pane { width: 32%; min-width: 220px; max-width: 60%; transition: width .15s ease; overflow-y: auto; flex-shrink: 0; }
    .price-tree-pane.is-collapsed { display: none; }
    .price-splitter { width: 8px; cursor: col-resize; background: linear-gradient(to right, transparent 2px, #dee2e6 2px, #dee2e6 6px, transparent 6px); user-select: none; flex-shrink: 0; }
    .price-splitter.is-hidden { display: none; }
    .price-table-pane { flex: 1; min-width: 0; overflow: hidden; display: flex; flex-direction: column; }
    .price-table-pane > .oa-card { display: flex; flex-direction: column; min-height: 0; }
    .price-table-pane #hot-container { flex: 1 1 auto; min-height: 0; }
    .price-table-pane #hot-container.is-hidden-panel { display: none !important; }
    .price-table-pane #fill-price-action-buttons { flex-shrink: 0; }
    .price-table-pane #cabinet-status-bar { flex-shrink: 0; }
    /* 视图模式：柜体 / 属性 互斥显示 */
    .price-workspace.view-mode-cabinet #attr-tree-pane,
    .price-workspace.view-mode-cabinet #attr-table-pane { display: none !important; }
    .price-workspace.view-mode-attr #price-tree-pane,
    .price-workspace.view-mode-attr #cabinet-table-pane { display: none !important; }
    .price-workspace.view-mode-attr #attr-tree-pane { display: block; }
    .price-workspace.view-mode-attr #attr-table-pane { display: flex; }
    .tree-node-link { border: 0; background: transparent; padding: 2px 4px; color: inherit; text-align: left; width: 100%; cursor: pointer; border-radius: 4px; }
    .tree-node-link:hover { color: #0d6efd; background-color: #f4f8ff; }
    /* "元件使用柜" 高亮（点击元件后短暂显示），淡蓝底 */
    .tree-node-link-usage { color: #0d6efd; font-weight: 700; background-color: #e7f1ff; }
    /* "当前选中柜" 高亮（用户主动点击的节点，持久），实心蓝底白字 */
    .tree-node-link-selected { color: #fff !important; font-weight: 700; background-color: #0d6efd !important; }
    .tree-node-link-selected:hover { color: #fff !important; background-color: #0b5ed7 !important; }
    .ht-ref-price-header { background-color: #d1e7dd !important; color: #0a3622 !important; font-weight: 600; }
    .ht-amount-header { background-color: #d6eaf8 !important; color: #1b4f72 !important; font-weight: 600; }
    .unsaved-badge { display: none; color: #dc3545; font-weight: 600; font-size: 0.85rem; }
    .unsaved-badge.is-visible { display: inline; }
    /* 价格异常检测着色 (Req 9.1, 9.2, 9.3) */
    .ht-price-empty { background-color: #f0f0f0 !important; }
    .ht-price-negative { background-color: #f8d7da !important; }
    .ht-price-deviation { background-color: #fff3cd !important; }
    /* 颜色图例 swatch */
    .legend-swatch { display: inline-block; width: 14px; height: 14px; border: 1px solid #ced4da; border-radius: 2px; vertical-align: middle; margin-right: 4px; }
    .legend-swatch.sw-empty { background-color: #f0f0f0; }
    .legend-swatch.sw-negative { background-color: #f8d7da; }
    .legend-swatch.sw-deviation { background-color: #fff3cd; }
    .legend-swatch.sw-ref { background-color: #d1e7dd; }
    .legend-swatch.sw-amount { background-color: #d6eaf8; }
    /* 控制柜拖拽排序 (Req 14.1, 14.5) */
    #tree-children-container li[draggable="true"] { cursor: grab; transition: opacity .15s ease; }
    #tree-children-container li[draggable="true"]:active { cursor: grabbing; }
    #tree-children-container li.drag-source { opacity: 0.4; }
    #tree-children-container li.drag-over-top { border-top: 2px solid #0d6efd; }
    #tree-children-container li.drag-over-bottom { border-bottom: 2px solid #0d6efd; }
    /* 进度看板徽章（spec: fill-progress-dashboard / Req B-1, B-2） */
    #fill-progress-badge .progress-chip { font-size: .8rem; padding: .25rem .5rem; }
    #fill-progress-badge .progress-chip.is-error { background-color: #f8d7da !important; color: #842029 !important; border-color: #f5c2c7 !important; }
    #fill-progress-badge #problem-list-toggle:disabled { opacity: .55; }
    /* 问题清单抽屉（spec: fill-progress-dashboard / Req B-3） */
    .problem-list-drawer { position: fixed; top: 0; right: 0; bottom: 0; width: 380px; max-width: 100vw; background: #fff; box-shadow: -2px 0 12px rgba(0,0,0,.12); z-index: 1045; display: flex; flex-direction: column; }
    .problem-list-drawer .drawer-header { display: flex; justify-content: space-between; align-items: center; padding: .75rem 1rem; border-bottom: 1px solid #dee2e6; }
    .problem-list-drawer .drawer-body { flex: 1; overflow-y: auto; padding: .5rem 1rem 1rem 1rem; }
    .problem-list-drawer .drawer-footer { padding: .5rem 1rem; border-top: 1px solid #dee2e6; background: #f8f9fa; font-size: .8rem; color: #6c757d; }
    .problem-list-drawer .drawer-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.15); z-index: -1; }
    .problem-list-group { margin-bottom: .75rem; }
    .problem-list-group .group-header { font-weight: 600; color: #0d6efd; padding: .25rem 0; cursor: pointer; user-select: none; display: flex; justify-content: space-between; align-items: center; }
    .problem-list-group .group-header:hover { background-color: #f4f8ff; border-radius: 4px; padding: .25rem .5rem; }
    .problem-list-group .group-items { list-style: none; padding-left: 0; margin-bottom: 0; }
    .problem-list-item { padding: .35rem .5rem; border-left: 3px solid transparent; cursor: pointer; font-size: .8rem; border-radius: 3px; }
    .problem-list-item:hover { background-color: #f4f8ff; }
    .problem-list-item .issue-badge { display: inline-block; min-width: 52px; padding: 0 .35rem; font-size: .7rem; line-height: 1.4; border-radius: 3px; margin-right: .35rem; vertical-align: middle; }
    .problem-list-item .issue-badge.issue-negative { background-color: #f8d7da; color: #842029; }
    .problem-list-item .issue-badge.issue-zero_price { background-color: #f0f0f0; color: #495057; }
    .problem-list-item .issue-badge.issue-deviation { background-color: #fff3cd; color: #664d03; }
    .problem-list-item .issue-badge.issue-missing_spec { background-color: #e7f1ff; color: #084298; }
    @@media (max-width: 768px) {
        .problem-list-drawer { width: 100vw; }
    }
    /* 行高亮闪烁（B-T6 跳转 + 高亮 2 秒） */
    @@keyframes hot-row-flash { 0% { background-color: #fff3cd; } 100% { background-color: transparent; } }
    .hot-row-flash { animation: hot-row-flash 2s ease-out; }
    /* ── 视图切换 Toggle ── */
    .view-toggle-group .btn { min-width: 80px; }
    /* ── 柜体视图树：折叠 + 二级子节点 ── */
    .tree-cabinet-row { display: flex; align-items: center; gap: 2px; }
    .tree-expand-btn { width: 22px; height: 22px; line-height: 1; color: #6c757d; text-decoration: none; }
    .tree-expand-btn:hover { color: #0d6efd; }
    .tree-level2-list { list-style: none; padding-left: 0; margin: 2px 0 4px 0; }
    .tree-level2-list.tree-level2-collapsed { display: none; }
    .tree-level2-item .tree-node-link { font-size: .82rem; color: #495057; padding: 1px 4px; }
    .tree-level2-item .tree-node-link:hover { color: #0d6efd; background-color: #f4f8ff; }
    .tree-level2-item .tree-node-link.has-children { font-weight: 500; }
    /* ── 附加费用项区块（主面板模式） ── */
    .additional-items-section { border: 1px solid #dee2e6; border-radius: 6px; padding: 8px; margin-bottom: 8px; background: #fafafa; }
    .additional-items-section.is-primary-panel { flex: 1 1 auto; min-height: 0; margin-bottom: 0; display: flex; flex-direction: column; border: none; background: transparent; padding: 0; }
    .additional-items-section.is-primary-panel .section-header { display: none; }
    .additional-items-section.is-primary-panel .section-body { flex: 1 1 auto; min-height: 0; display: flex; flex-direction: column; }
    .additional-items-section .section-header { display: flex; align-items: center; justify-content: space-between; cursor: pointer; user-select: none; font-size: .875rem; font-weight: 600; color: #495057; padding-bottom: 6px; }
    .additional-items-section .section-header:hover { color: #0d6efd; }
    .additional-items-section .section-body { overflow: hidden; }
    .additional-items-section .section-body.is-collapsed { display: none; }
    #hot-additional-container { min-height: 120px; width: 100%; }
    .additional-items-section.is-primary-panel #hot-additional-container { flex: 1 1 auto; min-height: 200px; }
    /* ── 属性视图树 ── */
    .attr-tree-node-link { border: 0; background: transparent; padding: 3px 6px; color: inherit; text-align: left; width: 100%; cursor: pointer; border-radius: 4px; font-size: .875rem; }
    .attr-tree-node-link:hover { color: #0d6efd; background-color: #f4f8ff; }
    .attr-tree-node-link-selected { color: #fff !important; font-weight: 700; background-color: #0d6efd !important; }
    .attr-tree-node-link-selected:hover { color: #fff !important; background-color: #0b5ed7 !important; }
    /* ── 属性视图右侧 ── */
    #hot-attr-container { flex: 1 1 auto; min-height: 200px; width: 100%; }
    .ht-placeholder-row td { background-color: #f8f9fa !important; color: #adb5bd !important; }
</style>

<div class="oa-card mb-2">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <button id="toggle-tree-btn" type="button" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-layout-sidebar-inset me-1"></i>隐藏目录树
            </button>
            <div class="btn-group btn-group-sm view-toggle-group" role="group" aria-label="视图切换">
                <button id="view-cabinet-btn" type="button" class="btn btn-primary" title="按控制柜查看">
                    <i class="bi bi-grid-1x2 me-1"></i>柜体视图
                </button>
                <button id="view-attr-btn" type="button" class="btn btn-outline-primary" title="按属性跨柜批量填写">
                    <i class="bi bi-table me-1"></i>属性视图
                </button>
            </div>
            <span class="small text-muted">报价单：<span class="fw-semibold text-dark">@Model.QuotationNo</span></span>
            <span id="unsaved-badge" class="unsaved-badge"><i class="bi bi-exclamation-circle me-1"></i>未保存</span>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <div id="fill-progress-badge" class="d-inline-flex align-items-center gap-2"
                 data-progress-url="@fillProgressUrl">
                <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle progress-chip"
                      title="已填价 / 元件总数">
                    <i class="bi bi-list-check me-1"></i>
                    <span id="progress-filled">0</span> / <span id="progress-total">0</span>
                    （<span id="progress-percent">–</span>）
                </span>
                <button id="problem-list-toggle" type="button"
                        class="btn btn-sm btn-outline-warning"
                        title="点击查看问题清单" disabled>
                    <i class="bi bi-exclamation-triangle me-1"></i>异常 <span id="anomaly-count">0</span>
                </button>
            </div>
            @if (Model.CanEdit)
            {
                <button id="auto-fill-price-btn" type="button" class="btn btn-sm btn-outline-warning"
                        data-auto-fill-url="@autoFillPriceUrl"
                        data-quotation-no="@Model.QuotationNo">
                    <i class="bi bi-lightning-charge me-1"></i>引用历史报价
                </button>
            }
            <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">返回列表</a>
        </div>
    </div>
    <div id="color-legend" class="d-none d-flex flex-wrap align-items-center gap-3 small text-muted mt-2 pt-2 border-top">
        <span class="fw-semibold">单价图例：</span>
        <span><span class="legend-swatch sw-empty"></span>空 / 0（未填写）</span>
        <span><span class="legend-swatch sw-negative"></span>负数（必须修正）</span>
        <span><span class="legend-swatch sw-deviation"></span>偏离均价 ±20%</span>
        <span class="text-muted">|</span>
        <span><span class="legend-swatch sw-ref"></span>参考价格列</span>
        <span><span class="legend-swatch sw-amount"></span>金额列</span>
    </div>
</div>

<div id="page-info-bar" class="alert alert-info py-2 px-3 small mb-2">
    提示：柜体视图 — 点击控制柜填写附加费用项，点击「器件」填写元件明细；属性视图 — 按属性跨柜批量填写；点击根节点可查看项目元件汇总。
</div>

<div class="price-workspace view-mode-cabinet" id="price-workspace">
    @* ══ 柜体视图：左侧树 ══ *@
    <div id="price-tree-pane" class="price-tree-pane">
        <div class="oa-card h-100 me-2 d-flex flex-column">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="small text-muted">目录树</span>
            </div>
            <ul class="list-unstyled mb-0 flex-grow-1 overflow-auto">
                <li class="fw-semibold mb-2">
                    <button id="tree-root-node" type="button" class="tree-node-link">
                        <i class="bi bi-diagram-3 me-1 text-primary"></i>
                        @(string.IsNullOrWhiteSpace(Model.QuotationName) ? Model.QuotationNo : Model.QuotationName)
                    </button>
                </li>
                <ul id="tree-children-container" class="list-unstyled mb-0">
                    @if (Model.TreeNodes.Count == 0)
                    {
                        <li class="text-muted small ms-4">暂无控制柜节点</li>
                    }
                    else
                    {
                        @foreach (var node in Model.TreeNodes)
                        {
                            <li class="ms-3 mb-1" data-node-type="@node.NodeType">
                                @if (node.NodeType == "leaf")
                                {
                                    <button type="button" class="tree-node-link" data-unit-no="@node.Code" data-node-type="leaf">
                                        <i class="bi bi-tag me-1 text-warning"></i>@node.Name
                                        <span class="text-muted small ms-1">(@node.Code)</span>
                                    </button>
                                }
                                else
                                {
                                    <div class="tree-cabinet-row">
                                        @if (node.Level2Children.Count > 0)
                                        {
                                            <button type="button" class="tree-expand-btn btn btn-link btn-sm p-0 flex-shrink-0"
                                                    aria-expanded="false" title="展开/折叠子节点">
                                                <i class="bi bi-chevron-right"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="tree-expand-btn flex-shrink-0" style="width:22px;"></span>
                                        }
                                        <button type="button" class="tree-node-link flex-grow-1" data-unit-no="@node.Code" data-node-type="cabinet">
                                            <i class="bi bi-dot"></i>@node.Name
                                            <span class="text-muted small ms-1">(@node.Code)</span>
                                        </button>
                                    </div>
                                    @if (node.Level2Children.Count > 0)
                                    {
                                        <ul class="tree-level2-list ms-3 tree-level2-collapsed">
                                            @foreach (var l2 in node.Level2Children)
                                            {
                                                <li class="tree-level2-item">
                                                    <button type="button"
                                                            class="tree-node-link @(l2.HasLevel3Children ? "has-children" : "")"
                                                            data-level2-code="@l2.Code"
                                                            data-parent-code="@node.Code"
                                                            data-has-children="@l2.HasLevel3Children.ToString().ToLower()">
                                                        @if (l2.HasLevel3Children)
                                                        {
                                                            <i class="bi bi-list-ul me-1 text-info"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-dash me-1 text-muted"></i>
                                                        }
                                                        @l2.Name
                                                    </button>
                                                </li>
                                            }
                                        </ul>
                                    }
                                }
                            </li>
                        }
                    }
                </ul>
            </ul>
        </div>
    </div>

    @* ══ 属性视图：左侧树 ══ *@
    <div id="attr-tree-pane" class="price-tree-pane">
        <div class="oa-card h-100 me-2 d-flex flex-column">
            <div class="mb-2 small text-muted">属性目录</div>
            <ul class="list-unstyled mb-0 flex-grow-1 overflow-auto">
                @foreach (var attr in Model.AttrNodes)
                {
                    <li class="mb-1">
                        <button type="button" class="attr-tree-node-link"
                                data-xlx="@attr.Xlx" data-attr-name="@attr.Name" data-attr-count="@attr.Count">
                            <i class="bi bi-layers me-1 text-secondary"></i>@attr.Name
                            <span class="text-muted small ms-1">(@attr.Count)</span>
                        </button>
                    </li>
                }
                <li class="mb-1">
                    <button type="button" class="attr-tree-node-link" data-xlx="0" data-attr-name="其他费用项" data-attr-count="">
                        <i class="bi bi-tag me-1 text-warning"></i>其他费用项
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <div id="price-splitter" class="price-splitter" aria-label="拖动调整左右宽度"></div>

    @* ══ 柜体视图：右侧内容区 ══ *@
    <div class="price-table-pane" id="cabinet-table-pane">
        <div class="oa-card h-100 ms-2 d-flex flex-column">
            <div id="cabinet-status-bar" class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2 small flex-shrink-0">
                <div>
                    <i class="bi bi-box-seam me-1 text-primary"></i>
                    <span class="text-muted">当前节点：</span>
                    <span id="current-node-label" class="fw-semibold text-dark">尚未选择</span>
                </div>
                <div>
                    <span class="text-muted">合计金额：</span>
                    <span id="current-node-total" class="fw-bold text-primary">¥0.00</span>
                </div>
            </div>

            @* 附加费用项（Level 2 叶节点） *@
            <div id="additional-items-section" class="additional-items-section d-none flex-shrink-0">
                <div class="section-header" id="additional-items-toggle">
                    <span><i class="bi bi-card-list me-1 text-secondary"></i>附加费用项
                        <span id="additional-items-count" class="text-muted small ms-1"></span>
                    </span>
                    <i class="bi bi-chevron-down" id="additional-items-chevron"></i>
                </div>
                <div class="section-body" id="additional-items-body">
                    <div id="hot-additional-container"
                         class="border rounded mt-1"
                         data-additional-url="@additionalItemsUrl"
                         data-save-leaf-url="@saveLeafItemsUrl"
                         data-quotation-no="@Model.QuotationNo"
                         data-license-key="53ea8-c2678-49b80-cb40f-4dad4">
                    </div>
                    <div class="small text-muted mt-1">
                        <i class="bi bi-info-circle me-1"></i>价格修改自动写入数据库，无需手动保存
                    </div>
                </div>
            </div>

            @* Level 3 元件列表（现有区块） *@
            <div id="hot-container"
                 class="border rounded flex-grow-1 is-hidden-panel"
                 style="min-height: 120px;"
                 data-license-key="53ea8-c2678-49b80-cb40f-4dad4"
                 data-components-url="@cabinetComponentsUrl"
                 data-project-summary-url="@projectComponentSummaryUrl"
                 data-save-project-summary-url="@saveProjectSummaryUrl"
                 data-cabinet-ref-bj-url="@cabinetRefBjUrl"
                 data-reference-price-url="@referencePriceUrl"
                 data-wzdh-sync-stats-url="@wzdhSyncStatsUrl"
                 data-apply-price-by-wzdh-url="@applyPriceByWzdhUrl"
                 data-quotation-no="@Model.QuotationNo">
            </div>
            <div id="component-usage-panel" class="alert alert-light border mt-2 d-none flex-shrink-0">
                <div class="fw-semibold mb-2">使用控制柜</div>
                <div id="component-usage-title" class="small text-muted mb-2"></div>
                <ul id="component-usage-list" class="list-unstyled mb-0 small"></ul>
            </div>
            <div id="fill-price-action-buttons" class="d-flex flex-wrap align-items-center gap-2 mt-2 flex-shrink-0">
                <form id="price-save-form" class="d-none" method="post">
                    @Html.AntiForgeryToken()
                </form>
                @if (Model.CanEdit)
                {
                    <span class="small text-muted">
                        <i class="bi bi-info-circle me-1"></i>价格修改自动写入数据库，无需手动保存（不允许增删行）
                    </span>
                }
            </div>
        </div>
    </div>

    @* ══ 属性视图：右侧内容区 ══ *@
    <div class="price-table-pane" id="attr-table-pane">
        <div class="oa-card h-100 ms-2 d-flex flex-column">
            <div id="attr-status-bar" class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2 small flex-shrink-0">
                <div>
                    <i class="bi bi-layers me-1 text-secondary"></i>
                    <span class="text-muted">当前属性：</span>
                    <span id="attr-node-label" class="fw-semibold text-dark">尚未选择</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted">合计金额：</span>
                    <span id="attr-node-total" class="fw-bold text-secondary">¥0.00</span>
                    @if (Model.CanEdit)
                    {
                        <button id="batch-fill-btn" type="button" class="btn btn-sm btn-outline-success d-none"
                                title="以首个有规格且单价>0的行为模板，批量填充所有空行">
                            <i class="bi bi-arrow-down-circle me-1"></i>批量填写
                        </button>
                    }
                </div>
            </div>
            <div id="hot-attr-container"
                 class="border rounded flex-grow-1"
                 style="min-height: 120px;"
                 data-attribute-url="@attributeItemsUrl"
                 data-save-leaf-url="@saveLeafItemsUrl"
                 data-quotation-no="@Model.QuotationNo"
                 data-license-key="53ea8-c2678-49b80-cb40f-4dad4">
            </div>
            <div class="small text-muted mt-2 flex-shrink-0">
                <i class="bi bi-info-circle me-1"></i>价格修改自动写入数据库，无需手动保存
            </div>
        </div>
    </div>
</div>

<div id="problem-list-drawer" class="problem-list-drawer d-none" aria-hidden="true">
    <div class="drawer-overlay"></div>
    <div class="drawer-header">
        <span class="fw-semibold"><i class="bi bi-exclamation-triangle me-1 text-warning"></i>问题清单</span>
        <button type="button" class="btn-close" id="problem-list-close" aria-label="关闭"></button>
    </div>
    <div id="problem-list-body" class="drawer-body">
        <div class="text-muted small text-center py-3">加载中…</div>
    </div>
    <div class="drawer-footer">
        <span id="problem-list-summary">共 0 条</span>
        <span class="ms-2 text-muted">提示：点击任意一条可跳转到对应行</span>
    </div>
</div>

@section Scripts {
    <script src="~/lib/handsontable/handsontable.full.min.js"></script>
    <script src="~/js/quotation-fill-price.js" asp-append-version="true"></script>
}


