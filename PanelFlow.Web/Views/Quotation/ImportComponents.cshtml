@model PanelFlow.Web.Models.Quotation.QuotationPriceViewModel
@{
    ViewData["Title"] = "导入元件";
    ViewData["BreadcrumbTitle"] = "导入元件";
    var uploadUrl = Url.Action("UploadImportExcel", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var saveExcelUrl = Url.Action("SaveImportExcel", "Quotation") ?? string.Empty;
    var savePlanUrl = Url.Action("SavePlan", "Quotation") ?? string.Empty;
    var exportPlanUrl = Url.Action("ExportPlanExcel", "Quotation", new { id = Model.QuotationNo }) ?? string.Empty;
    var rootDisplay = string.IsNullOrWhiteSpace(Model.QuotationName) ? Model.QuotationNo : Model.QuotationName;
    var hasExistingCabinets = Model.TreeNodes.Count > 0;
}
<link rel="stylesheet" href="~/lib/handsontable/handsontable.full.min.css" />
<link rel="stylesheet" href="~/css/quotation-import.css" asp-append-version="true" />

<div class="oa-import-toolbar" role="toolbar" aria-label="导入元件操作工具栏">
    <button id="toggle-tree-btn" type="button" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-layout-sidebar-inset me-1"></i>隐藏目录树
    </button>
    <div class="ms-auto d-flex gap-2 flex-wrap">
        <button id="open-excel-btn" type="button" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-file-earmark-excel me-1"></i>打开 Excel 元件表
        </button>
        <button id="check-data-btn" type="button" class="btn btn-sm btn-outline-warning" disabled>
            <i class="bi bi-clipboard2-check me-1"></i>数据检查
        </button>
        <button id="preview-tree-btn" type="button" class="btn btn-sm btn-outline-info" disabled>
            <i class="bi bi-diagram-3 me-1"></i>目录预览
        </button>
        <button id="save-excel-btn" type="button" class="btn btn-sm btn-outline-success" disabled title="仅导出当前页面表格（不含库内整单）">
            <i class="bi bi-download me-1"></i>另存表格
        </button>
        @if (hasExistingCabinets)
        {
            <button id="export-plan-excel-btn" type="button" class="btn btn-sm btn-outline-success" title="从数据库导出当前方案全部控制柜及元件">
                <i class="bi bi-box-arrow-down me-1"></i>导出方案 Excel
            </button>
        }
        else
        {
            <button id="export-plan-excel-btn" type="button" class="btn btn-sm btn-outline-success" disabled title="从数据库导出当前方案全部控制柜及元件">
                <i class="bi bi-box-arrow-down me-1"></i>导出方案 Excel
            </button>
        }
        <button id="save-plan-btn" type="button" class="btn btn-sm btn-primary" disabled>
            <i class="bi bi-save me-1"></i>保存方案
        </button>
    </div>
</div>

<div id="page-info-bar" class="alert alert-info py-2 px-3 small" role="status" aria-live="polite">
    提示：可通过“打开 Excel 元件表”导入数据；支持前 8 列，最大 5000 行，遇到连续 5 空行自动结束。「另存表格」仅备份页面表格；「导出方案 Excel」导出库内整单。
</div>

<div id="oa-save-busy" class="oa-save-busy d-none" aria-hidden="true" role="status" aria-live="assertive">
    <div class="oa-save-busy-card">
        <div class="spinner-border text-primary mb-2" role="presentation"></div>
        <div class="fw-semibold" id="oa-save-busy-title">正在保存方案…</div>
        <div class="oa-save-progress" id="oa-save-busy-progress">(0/0)</div>
        <div class="small text-muted mt-1">单元较多时请稍候，请勿关闭页面</div>
    </div>
</div>

<div class="oa-import-workspace">
    <aside id="tree-pane" aria-label="目录树">
        <div class="small text-muted mb-2">目录树</div>
        <ul class="oa-tree-root">
            <li class="fw-semibold mb-2">
                <button id="tree-root-node" type="button" class="oa-tree-link">
                    <i class="bi bi-diagram-3 me-1 text-primary"></i>@rootDisplay
                </button>
            </li>
            <ul id="tree-children-container" class="oa-tree-children">
                @if (Model.TreeNodes.Count == 0)
                {
                    <li class="oa-tree-empty">暂无控制柜节点</li>
                }
                else
                {
                    @foreach (var n in Model.TreeNodes)
                    {
                        var hasName = !string.IsNullOrWhiteSpace(n.Name);
                        var displayPrimary = hasName ? n.Name : n.Code;
                        <li>
                            <button type="button"
                                    class="oa-tree-link tree-node-link is-existing"
                                    data-unit-no="@n.Code"
                                    data-unit-name="@displayPrimary">
                                <i class="bi bi-dot"></i>@displayPrimary（@n.Code）
                            </button>
                        </li>
                    }
                }
            </ul>
        </ul>
    </aside>
    <div id="tree-splitter" role="separator" aria-orientation="vertical" aria-label="拖动调整左右宽度" tabindex="0"></div>
    <main id="grid-pane" aria-label="元件表格">
        <div id="hot-container"
             class="border rounded"
             data-license-key="53ea8-c2678-49b80-cb40f-4dad4"
             data-upload-url="@uploadUrl"
             data-save-url="@saveExcelUrl"
             data-save-plan-url="@savePlanUrl"
             data-export-plan-url="@exportPlanUrl"
             data-quotation-no="@Model.QuotationNo"
             data-current-status="@Model.CurrentStatus"
             data-has-existing-cabinets="@(hasExistingCabinets ? "1" : "0")"
             style="height: 100%;">
        </div>
        <form id="excel-upload-form" class="d-none" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input id="excel-file-input" type="file" name="file" accept=".xls,.xlsx" />
        </form>
    </main>
</div>

<div class="modal fade" id="preview-mode-modal" tabindex="-1" role="dialog" aria-labelledby="preview-mode-title" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="preview-mode-title">目录预览方式</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="关闭"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">当前报价单已有控制柜。请选择如何处理本次 Excel：</p>
                <ul class="small text-muted mb-0">
                    <li><strong>覆盖</strong>：清空原方案内容，仅保留本次 Excel 中的控制柜及元件。</li>
                    <li><strong>追加</strong>：保留原方案，将本次 Excel 中的控制柜追加到后面。</li>
                    <li><strong>取消</strong>：不做任何操作。</li>
                </ul>
            </div>
            <div class="modal-footer flex-wrap gap-2">
                <button type="button" class="btn btn-outline-danger" id="preview-mode-overwrite">覆盖原报价单</button>
                <button type="button" class="btn btn-primary" id="preview-mode-append">追加到原报价单</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="preview-mode-cancel">取消</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="save-plan-confirm-modal" tabindex="-1" role="dialog" aria-labelledby="save-plan-confirm-title" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="save-plan-confirm-title">确认</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="关闭"></button>
            </div>
            <div class="modal-body" id="save-plan-confirm-body">
                <!-- 内容由 quotation-import.js 中的 confirmWithModal 动态填充 -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="save-plan-confirm-cancel">取消</button>
                <button type="button" class="btn btn-primary" id="save-plan-confirm-ok">确认</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/handsontable/handsontable.full.min.js"></script>
    <script src="~/js/quotation-import.js" asp-append-version="true"></script>
}
