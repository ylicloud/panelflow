@model PanelFlow.Core.Models.LoginUser
@{
    ViewData["Title"] = "首页";
}

<div class="mb-4">
    <h5 class="fw-bold text-dark mb-1">你好，@Model?.DisplayName <span class="text-muted fw-normal fs-6">(@Model?.RoleName)</span></h5>
    <p class="text-muted small mb-0">@DateTime.Now.ToString("yyyy年MM月dd日 dddd")</p>
</div>

<!-- 快捷入口（根据角色显示） -->
<div class="row g-3 mb-4">
    @{
        var role = Model?.RoleName ?? "";
    }
    @if (role is "管理员" or "报价员" or "生产管理人员")
    {
        <div class="col-6 col-md-3">
            <a href="/Quotation/Index" class="text-decoration-none">
                <div class="oa-card oa-stat-card h-100">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 p-2" style="background:#eff6ff">
                            <i class="bi bi-file-text fs-4 text-primary"></i>
                        </div>
                        <div>
                            <div class="oa-stat-label">报价单</div>
                            <div class="oa-stat-value">-</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (role is "管理员" or "生产管理人员")
    {
        <div class="col-6 col-md-3">
            <a href="/Production/Index" class="text-decoration-none">
                <div class="oa-card oa-stat-card h-100" style="border-left-color:#16a34a">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 p-2" style="background:#f0fdf4">
                            <i class="bi bi-gear fs-4 text-success"></i>
                        </div>
                        <div>
                            <div class="oa-stat-label">生产任务</div>
                            <div class="oa-stat-value">-</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (role is "管理员" or "采购人员")
    {
        <div class="col-6 col-md-3">
            <a href="/Purchase/Index" class="text-decoration-none">
                <div class="oa-card oa-stat-card h-100" style="border-left-color:#d97706">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 p-2" style="background:#fffbeb">
                            <i class="bi bi-cart3 fs-4 text-warning"></i>
                        </div>
                        <div>
                            <div class="oa-stat-label">待采购</div>
                            <div class="oa-stat-value">-</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (role is "管理员" or "装配人员")
    {
        <div class="col-6 col-md-3">
            <a href="/Assembly/Index" class="text-decoration-none">
                <div class="oa-card oa-stat-card h-100" style="border-left-color:#7c3aed">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 p-2" style="background:#f5f3ff">
                            <i class="bi bi-tools fs-4 text-purple" style="color:#7c3aed"></i>
                        </div>
                        <div>
                            <div class="oa-stat-label">装配任务</div>
                            <div class="oa-stat-value">-</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (role is "管理员" or "质检人员")
    {
        <div class="col-6 col-md-3">
            <a href="/QualityCheck/Index" class="text-decoration-none">
                <div class="oa-card oa-stat-card h-100" style="border-left-color:#dc2626">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 p-2" style="background:#fef2f2">
                            <i class="bi bi-patch-check fs-4 text-danger"></i>
                        </div>
                        <div>
                            <div class="oa-stat-label">待质检</div>
                            <div class="oa-stat-value">-</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (role is "管理员" or "仓库人员")
    {
        <div class="col-6 col-md-3">
            <a href="/Inventory/Index" class="text-decoration-none">
                <div class="oa-card oa-stat-card h-100" style="border-left-color:#0891b2">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 p-2" style="background:#ecfeff">
                            <i class="bi bi-archive fs-4" style="color:#0891b2"></i>
                        </div>
                        <div>
                            <div class="oa-stat-label">库存品类</div>
                            <div class="oa-stat-value">-</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<!-- 系统公告区域 -->
<div class="oa-card">
    <h6 class="fw-semibold mb-3"><i class="bi bi-megaphone me-2 text-primary"></i>系统公告</h6>
    <p class="text-muted small mb-0">暂无公告</p>
</div>
