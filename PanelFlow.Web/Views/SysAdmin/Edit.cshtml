@model PanelFlow.Web.Controllers.UserEditViewModel
@{
    ViewData["Title"] = "编辑用户";
    var allRoles = (Dictionary<int, string>)ViewBag.AllRoles;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="oa-card">
            <h5 class="fw-bold mb-4"><i class="bi bi-pencil-square me-2"></i>编辑用户</h5>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success py-2 small">@TempData["SuccessMessage"]</div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger py-2 small">@TempData["ErrorMessage"]</div>
            }

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Username" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" style="display:none"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-semibold"></label>
                    <input asp-for="Username" class="form-control" disabled />
                    <div class="form-text">登录名不可修改</div>
                </div>

                <div class="mb-3">
                    <label asp-for="DisplayName" class="form-label fw-semibold"></label>
                    <input asp-for="DisplayName" class="form-control" maxlength="20" />
                    <span asp-validation-for="DisplayName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="form-label fw-semibold"></label>
                    <select asp-for="Role" class="form-select">
                        @foreach (var r in allRoles)
                        {
                            <option value="@r.Key">@r.Value</option>
                        }
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input asp-for="IsEnabled" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsEnabled" class="form-check-label fw-semibold">启用此用户</label>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Remark" class="form-label fw-semibold"></label>
                    <textarea asp-for="Remark" class="form-control" rows="2" maxlength="100"></textarea>
                    <span asp-validation-for="Remark" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill py-2 fw-semibold">
                        <i class="bi bi-check-lg me-1"></i>保存修改
                    </button>
                    <a href="@Url.Action("Users")" class="btn btn-outline-secondary py-2 fw-semibold">返回</a>
                </div>
            </form>
        </div>

        <!-- 密码重置 -->
        <div class="oa-card mt-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-key me-2 text-warning"></i>重置密码</h6>
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="username" value="@Model.Username" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">新密码</label>
                    <input type="password" name="newPassword" class="form-control"
                           required minlength="4" maxlength="20"
                           placeholder="输入新密码（4-20位）" autocomplete="new-password" />
                </div>
                <button type="submit" class="btn btn-warning w-100 py-2 fw-semibold"
                        onclick="return confirm('确定要重置此用户的密码吗？')">
                    <i class="bi bi-arrow-repeat me-1"></i>确认重置密码
                </button>
            </form>
        </div>
    </div>
</div>
