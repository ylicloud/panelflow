@model List<PanelFlow.Web.Controllers.UserListItemViewModel>
@{
    ViewData["Title"] = "用户管理";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-people me-2"></i>用户管理</h5>
    <a href="@Url.Action("Create")" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>新建用户
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success py-2 small alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger py-2 small alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
    </div>
}

<!-- 桌面端表格 -->
<div class="oa-card d-none d-md-block p-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 oa-table">
            <thead>
                <tr>
                    <th>登录名</th>
                    <th>姓名</th>
                    <th>角色</th>
                    <th class="text-center">状态</th>
                    <th>最后登录</th>
                    <th>备注</th>
                    <th class="text-center" style="width:80px">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr class="@(!u.IsEnabled ? "text-muted" : "")">
                        <td class="fw-semibold">@u.Username</td>
                        <td>@u.DisplayName</td>
                        <td><span class="badge bg-primary bg-opacity-10 text-primary">@u.RoleName</span></td>
                        <td class="text-center">
                            @if (u.IsEnabled)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success">启用</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-25 text-secondary">禁用</span>
                            }
                        </td>
                        <td class="text-muted small">@(u.LastLogin?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                        <td class="text-muted small text-truncate" style="max-width:150px" title="@u.Remark">@u.Remark</td>
                        <td class="text-center">
                            <a href="@Url.Action("Edit", new { id = u.Username })"
                               class="btn btn-sm btn-outline-primary py-0 px-2">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- 移动端卡片列表 -->
<div class="d-md-none">
    @foreach (var u in Model)
    {
        <a href="@Url.Action("Edit", new { id = u.Username })" class="text-decoration-none">
            <div class="oa-card mb-2 @(!u.IsEnabled ? "opacity-50" : "")">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="fw-semibold text-dark">@u.DisplayName
                            <span class="text-muted fw-normal small ms-1">(@u.Username)</span>
                        </div>
                        <div class="mt-1">
                            <span class="badge bg-primary bg-opacity-10 text-primary me-1">@u.RoleName</span>
                            @if (u.IsEnabled)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success">启用</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-25 text-secondary">禁用</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(u.Remark))
                        {
                            <div class="text-muted small mt-1">@u.Remark</div>
                        }
                    </div>
                    <div class="text-end">
                        <div class="text-muted small">@(u.LastLogin?.ToString("MM-dd HH:mm") ?? "—")</div>
                        <i class="bi bi-chevron-right text-muted mt-1"></i>
                    </div>
                </div>
            </div>
        </a>
    }
</div>
