@model PanelFlow.Web.Controllers.CustomerListViewModel
@{
    ViewData["Title"] = "客户列表";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-buildings me-2"></i>客户列表</h5>
    <div class="d-flex align-items-center gap-2">
        <span class="small text-muted">按最近维护时间倒序，共 @Model.Items.Count 条</span>
        <a href="@Url.Action("Create")" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg me-1"></i>新建客户
        </a>
    </div>
</div>

<div class="oa-card mb-3">
    <form method="get" asp-action="Index" class="row g-2 align-items-center">
        <div class="col-md-6 col-lg-5">
            <input type="text" name="keyword" value="@Model.Keyword" class="form-control form-control-sm"
                   placeholder="搜索公司编号/名称/别名/联系人/电话" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-sm btn-primary">
                <i class="bi bi-search me-1"></i>搜索
            </button>
            <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary ms-1">重置</a>
        </div>
    </form>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success py-2 small alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger py-2 small alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
    </div>
}

<div class="oa-card p-0 d-none d-md-block">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 oa-table">
            <thead>
            <tr>
                <th style="width: 70px;">序号</th>
                <th>公司名称</th>
                <th>公司编号</th>
                <th>公司别名</th>
                <th>联系人</th>
                <th>联系电话</th>
                <th>备注</th>
                <th class="text-center" style="width: 100px;">操作</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">暂无客户数据</td>
                </tr>
            }
            else
            {
                for (var i = 0; i < Model.Items.Count; i++)
                {
                    var item = Model.Items[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>
                            <a href="@Url.Action("Details", new { id = item.CompanyNo })" class="link-primary text-decoration-none fw-semibold">
                                @item.CompanyName
                            </a>
                        </td>
                        <td>@item.CompanyNo</td>
                        <td>@item.Alias</td>
                        <td>@item.Contact</td>
                        <td>@item.Phone</td>
                        <td>@item.Remark</td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-outline-primary py-0 px-2"
                               href="@Url.Action("Edit", new { id = item.CompanyNo })">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

<div class="d-md-none">
    @if (Model.Items.Count == 0)
    {
        <div class="oa-card text-center text-muted">暂无客户数据</div>
    }
    else
    {
        for (var i = 0; i < Model.Items.Count; i++)
        {
            var item = Model.Items[i];
            <div class="oa-card mb-2">
                <div class="small text-muted">序号：@(i + 1)</div>
                <div class="fw-semibold mt-1">
                    <a href="@Url.Action("Details", new { id = item.CompanyNo })" class="link-primary text-decoration-none">
                        @item.CompanyName
                    </a>
                </div>
                <div class="small text-muted mt-1">公司编号：@item.CompanyNo</div>
                <div class="small text-muted">公司别名：@item.Alias</div>
                <div class="small text-muted">联系人：@item.Contact</div>
                <div class="small text-muted">联系电话：@item.Phone</div>
                <div class="small text-muted">备注：@item.Remark</div>
                <div class="mt-2">
                    <a class="btn btn-sm btn-outline-primary w-100"
                       href="@Url.Action("Edit", new { id = item.CompanyNo })">
                        编辑
                    </a>
                </div>
            </div>
        }
    }
</div>
