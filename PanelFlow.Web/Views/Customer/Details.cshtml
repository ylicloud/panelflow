@model PanelFlow.Web.Controllers.CustomerDetailsViewModel
@{
    ViewData["Title"] = "客户详情";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-building me-2"></i>客户详情</h5>
    <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">返回客户列表</a>
</div>

<div class="row g-3">
    <div class="col-12">
        <div class="oa-card">
            <div class="fw-semibold mb-3 px-3 py-2 rounded-2 bg-light border-start border-primary border-4">
                公司信息
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="small text-muted">公司编号</div>
                    <div class="fw-semibold">@Model.Customer.CompanyNo</div>
                </div>
                <div class="col-md-4">
                    <div class="small text-muted">公司名称</div>
                    <div class="fw-semibold">@Model.Customer.CompanyName</div>
                </div>
                <div class="col-md-4">
                    <div class="small text-muted">公司别名</div>
                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.Customer.Alias) ? "—" : Model.Customer.Alias)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="oa-card">
            <div class="fw-semibold mb-3 px-3 py-2 rounded-2 bg-light border-start border-primary border-4">
                公司联系人
            </div>
            @if (Model.Contacts.Count == 0)
            {
                <div class="small text-muted">暂无联系人数据</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="width: 70px;">序号</th>
                                <th>联系人</th>
                                <th>电话</th>
                                <th>邮箱</th>
                            </tr>
                        </thead>
                        <tbody>
                        @for (var i = 0; i < Model.Contacts.Count; i++)
                        {
                            var contact = Model.Contacts[i];
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@contact.ContactName</td>
                                <td>@(string.IsNullOrWhiteSpace(contact.Phone) ? "—" : contact.Phone)</td>
                                <td>@(string.IsNullOrWhiteSpace(contact.Email) ? "—" : contact.Email)</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="col-12">
        <div class="oa-card">
            <div class="fw-semibold mb-3 px-3 py-2 rounded-2 bg-light border-start border-primary border-4">
                关联报价单
            </div>
            @if (Model.Quotations.Count == 0)
            {
                <div class="small text-muted">暂无关联报价单</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>报价单名称</th>
                                <th>方案编号</th>
                                <th>报价日期</th>
                                <th>当前状态</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var quotation in Model.Quotations)
                        {
                            <tr>
                                <td>@(string.IsNullOrWhiteSpace(quotation.QuotationName) ? "—" : quotation.QuotationName)</td>
                                <td>@quotation.QuotationNo</td>
                                <td>@(quotation.CreatedAt?.ToString("yyyy-MM-dd") ?? "—")</td>
                                <td>@PanelFlow.Web.Controllers.CustomerDetailsViewModel.GetQuotationStatusText(quotation.CurrentStatus)</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
