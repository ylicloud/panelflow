@model PanelFlow.Web.Controllers.ContractEditViewModel
@{
    ViewData["Title"] = "编辑制造合同";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2"></i>编辑制造合同</h5>
    <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>返回列表
    </a>
</div>

<div class="oa-card">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
        <input asp-for="ContractNo" type="hidden" />

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">合同编号</label>
                <input class="form-control form-control-sm" value="@Model.ContractNo" readonly />
            </div>
            <div class="col-md-8">
                <label asp-for="ProjectName" class="form-label"></label>
                <input asp-for="ProjectName" class="form-control form-control-sm" />
                <span asp-validation-for="ProjectName" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="SignDate" class="form-label"></label>
                <input asp-for="SignDate" type="date" class="form-control form-control-sm" />
                <span asp-validation-for="SignDate" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="DeliveryDate" class="form-label"></label>
                <input asp-for="DeliveryDate" type="date" class="form-control form-control-sm" />
                <span asp-validation-for="DeliveryDate" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Owner" class="form-label"></label>
                <input asp-for="Owner" class="form-control form-control-sm" />
                <span asp-validation-for="Owner" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="CustomerNo" class="form-label"></label>
                <input asp-for="CustomerNo" class="form-control form-control-sm" />
                <span asp-validation-for="CustomerNo" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="SignCompany" class="form-label"></label>
                <input asp-for="SignCompany" class="form-control form-control-sm" />
                <span asp-validation-for="SignCompany" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="CurrentStatus" class="form-label"></label>
                <input asp-for="CurrentStatus" type="number" class="form-control form-control-sm" />
                <span asp-validation-for="CurrentStatus" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="TotalAmount" class="form-label"></label>
                <input asp-for="TotalAmount" type="number" step="0.0001" class="form-control form-control-sm" />
                <span asp-validation-for="TotalAmount" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="ContractContent" class="form-label"></label>
                <input asp-for="ContractContent" class="form-control form-control-sm" />
                <span asp-validation-for="ContractContent" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Remark" class="form-label"></label>
                <textarea asp-for="Remark" rows="3" class="form-control form-control-sm"></textarea>
                <span asp-validation-for="Remark" class="text-danger small"></span>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-primary">
                <i class="bi bi-check2 me-1"></i>保存修改
            </button>
            <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">取消</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
