@model PanelFlow.Web.Controllers.ChangePasswordViewModel
@{
    ViewData["Title"] = "修改密码";
    ViewData["BreadcrumbTitle"] = "修改密码";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="oa-card">
            <h5 class="fw-bold mb-4"><i class="bi bi-key me-2"></i>修改密码</h5>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success py-2 small">@TempData["SuccessMessage"]</div>
            }

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="mb-3">
                    <label asp-for="OldPassword" class="form-label fw-semibold"></label>
                    <input asp-for="OldPassword" class="form-control" autocomplete="current-password" />
                    <span asp-validation-for="OldPassword" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                    <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="bi bi-check-lg me-1"></i>确认修改
                </button>
            </form>
        </div>
    </div>
</div>
